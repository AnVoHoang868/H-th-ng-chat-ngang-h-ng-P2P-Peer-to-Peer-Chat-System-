{
  "name": "p2p-chat-system",
  "version": "1.0.0",
  "description": "P2P Chat System using Node.js, TypeScript, Express, and Socket.io",
  "main": "index.js",
  "scripts": {
    "start:server": "ts-node src/server/index.ts",
    "dev:server": "nodemon --watch src --ext ts,json --exec ts-node src/server/index.ts",
    "start:peer": "ts-node src/peer/index.ts",
    "dev:peer": "nodemon --watch src --ext ts,json --exec ts-node src/peer/index.ts",
    "build": "tsc"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
